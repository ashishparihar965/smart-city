PORT=5000
NODE_ENV=development
TRUST_PROXY=1

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smart-city?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Uploads (local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend API/Socket URLs are set in `frontend/.env`

# Email (optional — Nodemailer SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=SmartCity <noreply@smartcity.com>